{
  "family": "polymarket-bot",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "taskRoleArn": "arn:aws:iam::688567279867:role/polymarket-bot-task-role",
  "executionRoleArn": "arn:aws:iam::688567279867:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "polymarket-bot",
      "image": "688567279867.dkr.ecr.eu-west-1.amazonaws.com/polymarket-bot:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8888,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "POLYMARKET_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLYMARKET_PRIVATE_KEY::"
        },
        {
          "name": "POLYMARKET_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLYMARKET_API_KEY::"
        },
        {
          "name": "POLYMARKET_API_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLYMARKET_API_SECRET::"
        },
        {
          "name": "POLYMARKET_API_PASSPHRASE",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLYMARKET_API_PASSPHRASE::"
        },
        {
          "name": "POLYMARKET_CHAIN_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLYMARKET_CHAIN_ID::"
        },
        {
          "name": "POLYMARKET_FUNDER",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLYMARKET_FUNDER::"
        },
        {
          "name": "MODE",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:MODE::"
        },
        {
          "name": "BANKROLL",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:BANKROLL::"
        },
        {
          "name": "MAX_POSITION_PCT",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:MAX_POSITION_PCT::"
        },
        {
          "name": "DAILY_LOSS_CAP_PCT",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:DAILY_LOSS_CAP_PCT::"
        },
        {
          "name": "KELLY_FRACTION",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:KELLY_FRACTION::"
        },
        {
          "name": "MIN_EV_THRESHOLD",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:MIN_EV_THRESHOLD::"
        },
        {
          "name": "DIRECTIONAL_ENTRY_SECONDS",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:DIRECTIONAL_ENTRY_SECONDS::"
        },
        {
          "name": "DIRECTIONAL_MIN_MOVE_PCT",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:DIRECTIONAL_MIN_MOVE_PCT::"
        },
        {
          "name": "MAX_MARKET_PRICE",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:MAX_MARKET_PRICE::"
        },
        {
          "name": "ASSETS",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:ASSETS::"
        },
        {
          "name": "PAIRS",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:PAIRS::"
        },
        {
          "name": "WATCH_PAIRS",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:WATCH_PAIRS::"
        },
        {
          "name": "DATA_COLLECTION_MODE",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:DATA_COLLECTION_MODE::"
        },
        {
          "name": "LOG_LEVEL",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:LOG_LEVEL::"
        },
        {
          "name": "MAX_TRADE_USD",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:MAX_TRADE_USD::"
        },
        {
          "name": "POLY_BUILDER_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLY_BUILDER_API_KEY::"
        },
        {
          "name": "POLY_BUILDER_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLY_BUILDER_SECRET::"
        },
        {
          "name": "POLY_BUILDER_PASSPHRASE",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:POLY_BUILDER_PASSPHRASE::"
        },
        {
          "name": "EARLY_ENTRY_ENABLED",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:EARLY_ENTRY_ENABLED::"
        },
        {
          "name": "EARLY_ENTRY_LGBM_THRESHOLD",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:EARLY_ENTRY_LGBM_THRESHOLD::"
        },
        {
          "name": "EARLY_ENTRY_MAX_ASK",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:EARLY_ENTRY_MAX_ASK::"
        },
        {
          "name": "EARLY_ENTRY_MAX_BET",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:EARLY_ENTRY_MAX_BET::"
        },
        {
          "name": "OPPORTUNITY_BOT_PAUSED",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:OPPORTUNITY_BOT_PAUSED::"
        },
        {
          "name": "SCENARIO_C_ENABLED",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:SCENARIO_C_ENABLED::"
        },
        {
          "name": "EARLY_ENTRY_ROTATE_ENABLED",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:688567279867:secret:polymarket-bot-env-QogeV2:EARLY_ENTRY_ROTATE_ENABLED::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/polymarket-bot",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "polybot"
        }
      }
    }
  ]
}
